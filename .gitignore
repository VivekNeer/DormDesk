# .gitignore for DormDesk

# ──────────────────────────────────────────────
# Secrets — NEVER commit these
# ──────────────────────────────────────────────
.env
*.pem
*.key

# ──────────────────────────────────────────────
# Node.js
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────
# React / Vite build output
# ──────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ──────────────────────────────────────────────
# OS & Editor files
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log
