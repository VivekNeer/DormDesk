# ──────────────────────────────────────────────
# DormDesk Backend — Environment Variables
# Copy this to .env on the EC2 host and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────

# ── Database (AWS RDS MySQL) ──────────────────
DB_HOST=<rds-endpoint>.rds.amazonaws.com
DB_PORT=3306
DB_NAME=dormdesk
DB_USER=admin
DB_PASS=changeme

# ── AWS Cognito ───────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── App ───────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Phase 2 only (leave empty in MVP) ─────────
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@dormdesk.com
